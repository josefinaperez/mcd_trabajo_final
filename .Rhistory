library(ggplot2)
library(readr)
library(purrr)
library(stringr)
# Ruta a la carpeta de outputs
output_dir <- "data/outputs/sdm_parallel"
# Listar todos los archivos de dataset model-ready
dataset_files <- list.files(path = output_dir, pattern = "sdm_dataset_model_ready.csv", full.names = TRUE, recursive = TRUE)
# Iterar sobre cada archivo y generar el gráfico
walk(dataset_files, function(file_path) {
# Leer el dataset
df <- read_csv(file_path, show_col_types = FALSE)
# Extraer el nombre del archivo para obtener los parámetros
run_id <- basename(dirname(file_path))
# Mostrar el título con los parámetros
cat("\n\n### Parámetros del dataset: `", run_id, "`\n\n")
# Mostrar el gráfico
print(plot_points_in_map(df, color_by_class = TRUE))
})
